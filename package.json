{
  "name": "api-orquestrador",
  "version": "0.1.0",
  "private": true,
  "description": "GraphQL API orquestradora do sascar-sdk",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "postinstall": "node src/scripts/postinstall.js",
    "build": "tsc",
    "build:tui": "node scripts/build-tui.cjs",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc --noEmit --project tsconfig.scripts.json",
    "benchmark:sascar": "tsx scripts/benchmark-sascar.ts",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:seed": "tsx src/scripts/seed-admin.ts",
    "db:reset-admin": "tsx src/scripts/reset-admin.ts",
    "db:reset": "tsx src/scripts/migrate.ts --reset",
    "tui": "npm run build:tui && node dist-tui/index.js"
  },
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "bcrypt": "^5.1.1",
    "chalk": "^5.6.2",
    "clipboardy": "^4.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.30.0",
    "env-paths": "^3.0.0",
    "graphql": "^16.8.1",
    "graphql-request": "^7.4.0",
    "graphql-tag": "^2.12.6",
    "ink": "^5.2.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "react": "^18.3.1",
    "sascar-sdk": "github:MartielLima/sascar-sdk#v1.1.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/ink": "^0.5.2",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.4",
    "@types/node-cron": "^3.0.10",
    "@types/pg": "^8.10.9",
    "@types/react": "^18.3.31",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "drizzle-kit": "^0.20.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "ink-testing-library": "^4.0.0",
    "jest": "^29.7.0",
    "nock": "^14.0.0",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
